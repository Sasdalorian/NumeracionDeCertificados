---
import { Button } from '@radix-ui/themes';

---
<header>
    <img src="LogoHCVB.jpg" alt="Logo HCVB" class="logo-esquina">
    <h1 class="verdanatext titulo-centro">Enumerar Certificados Historicos</h1>
</header>

<form class="form verdanatext" id="pdfForm">

    <label>Selecciona los archivos PDF que desea enumerar:</label>
    <input type="file" accept="application/pdf" multiple name="pdfs" required>

    <div>
        <label>Número inicial:</label>
        <input type="number" id="numeroInicial" min="1" class="ancho5rem" required>
    </div>

    <Button type="submit" variant="solid" size="2">Enumerar</Button>
</form>

<section class="verdanatext">
    <h3>Uso:</h3>
    <p>1. Este Enumerador de Certificados permite enumerar archivos pdf.</p>
    <p>2. Los archivos deben estar ordenados por número o alfabeticamente.</p>
    <p>3. Al hacer clic en “Enumerar”, se descargarán los archivos PDF numerados a partir del número seleccionado.<p> 
</section>

<script type="module">
import { PDFDocument, rgb, StandardFonts } from 'https://cdn.skypack.dev/pdf-lib@1.17.1';

document.getElementById('pdfForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const files = document.querySelector('input[type="file"][name="pdfs"]').files;
    const numeroInicial = parseInt(document.getElementById('numeroInicial').value, 10);

    const filesArr = Array.from(files).sort((a, b) => a.name.localeCompare(b.name));
    for (let i = 0; i < filesArr.length; i++) {
        const file = filesArr[i];
        const numero = numeroInicial + i;
        const texto = `CRT. N° ${numero}`;
        const arrayBuffer = await file.arrayBuffer();
        const pdfDoc = await PDFDocument.load(arrayBuffer);
        const pages = pdfDoc.getPages();

        if (pages.length > 0) {
            const firstPage = pages[0];
            const { width, height } = firstPage.getSize();
            const font = await pdfDoc.embedFont(StandardFonts.Helvetica);
            firstPage.drawText(texto, {
                x: 20,
                y: height - 30,
                size: 14,
                font: font,
                color: rgb(0, 0, 0)
            });
        }
        const pdfBytes = await pdfDoc.save();
        const blob = new Blob([pdfBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = file.name;
        link.style.display = 'none';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    document.getElementById('pdfForm').reset();
});
</script>
